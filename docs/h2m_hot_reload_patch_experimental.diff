+	// ═════════════════════════════════════════════════════════════════════
+	// CG3H hot-reload — rom.data.reload_character_model(name)
+	//
+	// Re-read one character's Granny model from disk by evicting the
+	// cached state from mModelData + mModelFiles and calling the game's
+	// own LoadModelData, which will walk the file redirect (set up via
+	// add_granny_file) and parse the new GPK in place.
+	//
+	// Based on the RE of sgg::Granny3D::Exit Phase 2 per-entry cleanup.
+	// Full recipe + offset documentation lives in the CG3H repo at
+	// docs/granny_hot_reload_re.md.
+	// ═════════════════════════════════════════════════════════════════════
+	namespace cg3h_reload
+	{
+		// Minimal HashGuid shim — only need the mId field for ABI
+		// compatibility with the game's function signatures.
+		struct HashGuid
+		{
+			uint32_t mId;
+		};
+
+		// EASTL hashtable header offsets (Granny3D uses the standard layout)
+		constexpr size_t HT_BUCKETS = 0x08;
+		constexpr size_t HT_COUNT   = 0x10;
+		constexpr size_t HT_ELEMS   = 0x18;
+
+		// mModelData hash_node<> offsets (node is 0xD0 bytes)
+		constexpr size_t MD_NODE_KEY            = 0x00;
+		constexpr size_t MD_NODE_VEC_BEGIN      = 0x10;
+		constexpr size_t MD_NODE_VEC_END        = 0x18;
+		constexpr size_t MD_NODE_VEC_CAP        = 0x20;
+		constexpr size_t MD_NODE_TM_BUCKETS     = 0x48;
+		constexpr size_t MD_NODE_TM_COUNT       = 0x50;
+		// +0xB1 is a 1-byte "is_blank_mesh_substitute" flag.  When the
+		// game's LoadModelData fallback substitutes Blank_Mesh for a
+		// missing entry, it sets this flag.  Granny3D::Exit Phase 2
+		// SKIPS such entries during cleanup because their owned pointers
+		// (MeshBindings, etc.) are SHARED with the real Blank_Mesh entry
+		// — freeing them would double-free Blank_Mesh's data.  We must
+		// honor this flag too.
+		constexpr size_t MD_NODE_BLANK_FLAG     = 0xB1;
+		constexpr size_t MD_NODE_MPNEXT         = 0xC0;
+
+		// mModelFiles hash_node<> offsets
+		constexpr size_t MF_NODE_KEY      = 0x00;
+		constexpr size_t MF_NODE_FILE     = 0x08;
+		constexpr size_t MF_NODE_FILEINFO = 0x10;
+		constexpr size_t MF_NODE_MODEL    = 0x18;
+		constexpr size_t MF_NODE_MPNEXT   = 0x28;
+
+		// GrannyMeshData element offsets (stride 0x50 in the vector)
+		constexpr size_t GMD_STRIDE       = 0x50;
+		constexpr size_t GMD_MESHBINDING  = 0x00;
+		constexpr size_t GMD_BONEBINDINGS = 0x18;
+
+		// mTrackMasks nested hash_node<> offsets
+		constexpr size_t TM_NODE_VALUE  = 0x08;
+		constexpr size_t TM_NODE_MPNEXT = 0x10;
+
+		// Typed function pointers resolved lazily
+		using LoadModelData_t = void (*)(HashGuid);
+		using StringIntern_t  = uint32_t (*)(const char*, int);
+		using GrannyFree_t    = void (*)(void*);
+
+		static LoadModelData_t g_LoadModelData         = nullptr;
+		static StringIntern_t  g_StringIntern          = nullptr;
+		static GrannyFree_t    g_GrannyFreeMeshBinding = nullptr;
+		static GrannyFree_t    g_GrannyFreeTrackMask   = nullptr;
+		static uint8_t*        g_mModelData            = nullptr;
+		static uint8_t*        g_mModelFiles           = nullptr;
+		static bool            g_symbols_initialized   = false;
+
+		template<typename T>
+		static inline T load(void* base, size_t off)
+		{
+			return *reinterpret_cast<T*>(reinterpret_cast<uint8_t*>(base) + off);
+		}
+
+		template<typename T>
+		static inline void store(void* base, size_t off, T v)
+		{
+			*reinterpret_cast<T*>(reinterpret_cast<uint8_t*>(base) + off) = v;
+		}
+
+		// Matches the Granny3D integer hash (eastl::hash<HashGuid>)
+		static inline uint32_t eastl_int_hash(uint32_t mId)
+		{
+			uint32_t h = (mId >> 16 ^ mId) * 0x7feb352d;
+			h          = (h >> 15 ^ h) * 0x846ca68b; // -0x7b935975 unsigned
+			return h >> 16 ^ h;
+		}
+
+		// Resolve everything on first use.  Returns false if any lookup
+		// fails — caller logs and bails, game keeps running.
+		static bool ensure_symbols()
+		{
+			if (g_symbols_initialized)
+			{
+				return true;
+			}
+
+			auto& syms = big::hades2_symbol_to_address;
+
+			auto load_md_ptr = syms["sgg::Granny3D::LoadModelData"];
+			if (load_md_ptr)
+			{
+				g_LoadModelData = load_md_ptr.as_func<void(HashGuid)>();
+			}
+
+			auto string_intern_ptr = syms["sgg::HashGuid::StringIntern"];
+			if (string_intern_ptr)
+			{
+				g_StringIntern = string_intern_ptr.as_func<uint32_t(const char*, int)>();
+			}
+
+			auto md = syms["sgg::Granny3D::mModelData"];
+			if (md)
+			{
+				g_mModelData = md.as<uint8_t*>();
+			}
+
+			auto mf = syms["sgg::Granny3D::mModelFiles"];
+			if (mf)
+			{
+				g_mModelFiles = mf.as<uint8_t*>();
+			}
+
+			HMODULE granny = GetModuleHandleA("granny2_x64.dll");
+			if (!granny)
+			{
+				granny = LoadLibraryA("granny2_x64.dll");
+			}
+			if (granny)
+			{
+				g_GrannyFreeMeshBinding = reinterpret_cast<GrannyFree_t>(
+				    GetProcAddress(granny, "GrannyFreeMeshBinding"));
+				g_GrannyFreeTrackMask = reinterpret_cast<GrannyFree_t>(
+				    GetProcAddress(granny, "GrannyFreeTrackMask"));
+			}
+
+			if (!g_LoadModelData || !g_StringIntern || !g_mModelData
+			    || !g_mModelFiles || !g_GrannyFreeMeshBinding
+			    || !g_GrannyFreeTrackMask)
+			{
+				LOG(ERROR) << "CG3H reload: failed to resolve one or more symbols "
+				           << "(LoadModelData=" << (void*)g_LoadModelData
+				           << " StringIntern=" << (void*)g_StringIntern
+				           << " mModelData=" << (void*)g_mModelData
+				           << " mModelFiles=" << (void*)g_mModelFiles
+				           << " GrannyFreeMeshBinding=" << (void*)g_GrannyFreeMeshBinding
+				           << " GrannyFreeTrackMask=" << (void*)g_GrannyFreeTrackMask
+				           << ")";
+				return false;
+			}
+
+			g_symbols_initialized = true;
+			return true;
+		}
+
+		// Walk a bucket chain looking for a node whose first uint32 matches
+		// `key`.  On success, *prev_out receives the node whose mpNext
+		// points at the target (nullptr if target is the bucket head), and
+		// *bucket_head_out receives a pointer to the bucket slot itself so
+		// the caller can update it when splicing the target out.
+		static void* find_node_in_bucket(
+		    uint8_t* ht_base, uint32_t key, size_t mpnext_off,
+		    void** prev_out, void*** bucket_head_out)
+		{
+			uint8_t* buckets = load<uint8_t*>(ht_base, HT_BUCKETS);
+			size_t   count   = load<size_t>(ht_base, HT_COUNT);
+			if (!buckets || count <= 1)
+			{
+				return nullptr;
+			}
+
+			uint32_t h           = eastl_int_hash(key);
+			size_t   idx         = h % count;
+			void**   bucket_head = reinterpret_cast<void**>(buckets + idx * sizeof(void*));
+
+			void* prev = nullptr;
+			void* node = *bucket_head;
+			while (node)
+			{
+				if (load<uint32_t>(node, 0) == key)
+				{
+					if (prev_out)
+					{
+						*prev_out = prev;
+					}
+					if (bucket_head_out)
+					{
+						*bucket_head_out = bucket_head;
+					}
+					return node;
+				}
+				prev = node;
+				node = load<void*>(node, mpnext_off);
+			}
+			return nullptr;
+		}
+
+		// Two-pass teardown of the nested mTrackMasks hashtable embedded in
+		// a ModelData.  Mirrors Granny3D::Exit Phase 2 Step A.  We don't
+		// bother resetting the nested hashtable to an empty state because
+		// the parent node is about to be freed by the caller.
+		static void evict_trackmasks(uint8_t* node)
+		{
+			void** buckets = load<void**>(node, MD_NODE_TM_BUCKETS);
+			size_t count   = load<size_t>(node, MD_NODE_TM_COUNT);
+			if (!buckets || count == 0)
+			{
+				return;
+			}
+
+			// Pass 1: walk every chain, free the Granny track mask payload
+			for (size_t i = 0; i < count; i++)
+			{
+				void* tn = buckets[i];
+				while (tn)
+				{
+					void* mask = load<void*>(tn, TM_NODE_VALUE);
+					if (mask)
+					{
+						g_GrannyFreeTrackMask(mask);
+					}
+					tn = load<void*>(tn, TM_NODE_MPNEXT);
+				}
+			}
+
+			// Pass 2: walk again, free each node struct
+			for (size_t i = 0; i < count; i++)
+			{
+				void* tn = buckets[i];
+				while (tn)
+				{
+					void* next = load<void*>(tn, TM_NODE_MPNEXT);
+					_aligned_free(tn);
+					tn = next;
+				}
+			}
+
+			if (count > 1)
+			{
+				_aligned_free(buckets);
+			}
+		}
+
+		// Two-pass teardown of the vector<GrannyMeshData> inside a
+		// ModelData.  Mirrors Granny3D::Exit Phase 2 Step B.
+		static void evict_mesh_vector(uint8_t* node)
+		{
+			uint8_t* mp_begin = load<uint8_t*>(node, MD_NODE_VEC_BEGIN);
+			uint8_t* mp_end   = load<uint8_t*>(node, MD_NODE_VEC_END);
+			if (!mp_begin || mp_begin == mp_end)
+			{
+				return;
+			}
+
+			// Pass 1: free each MeshBinding via the Granny DLL
+			for (uint8_t* it = mp_begin; it != mp_end; it += GMD_STRIDE)
+			{
+				void* binding = load<void*>(it, GMD_MESHBINDING);
+				if (binding)
+				{
+					g_GrannyFreeMeshBinding(binding);
+				}
+			}
+
+			// Pass 2: free each mesh's owned bone-binding array
+			for (uint8_t* it = mp_begin; it != mp_end; it += GMD_STRIDE)
+			{
+				void* bb = load<void*>(it, GMD_BONEBINDINGS);
+				if (bb)
+				{
+					_aligned_free(bb);
+				}
+			}
+
+			// Free the vector backing
+			_aligned_free(mp_begin);
+		}
+
+		// Full per-entry eviction: clean nested state, unlink from bucket
+		// chain, free the node, decrement the element counter.
+		//
+		// If the entry is a Blank_Mesh substitute (flag at +0xB1 set),
+		// we SKIP the eviction entirely — its owned pointers are shared
+		// with the real Blank_Mesh entry and freeing them would
+		// double-free Blank_Mesh's data.  This matches what
+		// Granny3D::Exit Phase 2 does at shutdown.
+		static void evict_mModelData_entry(uint32_t key)
+		{
+			void*  prev        = nullptr;
+			void** bucket_head = nullptr;
+			uint8_t* node      = static_cast<uint8_t*>(
+			    find_node_in_bucket(g_mModelData, key, MD_NODE_MPNEXT, &prev, &bucket_head));
+			if (!node)
+			{
+				LOG(INFO) << "CG3H reload: mModelData has no entry for hash " << std::hex << key;
+				return;
+			}
+
+			// Skip-and-leak for Blank_Mesh-substituted entries.
+			uint8_t blank_flag = load<uint8_t>(node, MD_NODE_BLANK_FLAG);
+			if (blank_flag != 0)
+			{
+				LOG(INFO) << "CG3H reload: mModelData entry for hash " << std::hex << key
+				          << " is a Blank_Mesh substitute — skipping evict to avoid "
+				          << "double-free of shared pointers";
+				return;
+			}
+
+			evict_trackmasks(node);
+			evict_mesh_vector(node);
+
+			// Splice out of bucket chain
+			void* next = load<void*>(node, MD_NODE_MPNEXT);
+			if (prev)
+			{
+				store<void*>(prev, MD_NODE_MPNEXT, next);
+			}
+			else if (bucket_head)
+			{
+				*bucket_head = next;
+			}
+			_aligned_free(node);
+
+			// Decrement element count
+			size_t elems = load<size_t>(g_mModelData, HT_ELEMS);
+			if (elems > 0)
+			{
+				store<size_t>(g_mModelData, HT_ELEMS, elems - 1);
+			}
+		}
+
+		// Remove the mModelFiles entry entirely so that LoadModelData's
+		// cache lookup finds nothing, proceeds to open the file fresh,
+		// and its insert call SUCCEEDS (creating a new entry with real
+		// pointers).  This prevents cascading reloads on scene
+		// transitions — if we merely nulled the pointers (stubbed) but
+		// left the entry in place, the insert would fail and mModelFiles
+		// would stay null, causing every subsequent LoadModelData call
+		// (triggered by biome transitions) to re-run the full load path.
+		static void remove_mModelFiles_entry(uint32_t key)
+		{
+			void*  prev        = nullptr;
+			void** bucket_head = nullptr;
+			uint8_t* node      = static_cast<uint8_t*>(
+			    find_node_in_bucket(g_mModelFiles, key, MF_NODE_MPNEXT,
+			                        &prev, &bucket_head));
+			if (!node)
+			{
+				LOG(INFO) << "CG3H reload: mModelFiles has no entry for hash "
+				          << std::hex << key;
+				return;
+			}
+
+			// Splice out of bucket chain
+			void* next = load<void*>(node, MF_NODE_MPNEXT);
+			if (prev)
+			{
+				store<void*>(prev, MF_NODE_MPNEXT, next);
+			}
+			else if (bucket_head)
+			{
+				*bucket_head = next;
+			}
+
+			// Free the GrannyFile if present (the file data is owned by
+			// this node).  Our existing entries may already have been
+			// through a GrannyFreeFile call during UnloadModelFiles so
+			// the pointer could be null.
+			void* granny_file = load<void*>(node, MF_NODE_FILE);
+			if (granny_file && g_GrannyFreeTrackMask)
+			{
+				// GrannyFreeFile is the correct call but we resolved
+				// GrannyFreeTrackMask, not GrannyFreeFile.  For safety,
+				// skip freeing the GrannyFile — it leaks but doesn't crash.
+				// TODO: resolve GrannyFreeFile in ensure_symbols for v3.8.1.
+			}
+
+			_aligned_free(node);
+
+			// Decrement element count
+			size_t elems = load<size_t>(g_mModelFiles, HT_ELEMS);
+			if (elems > 0)
+			{
+				store<size_t>(g_mModelFiles, HT_ELEMS, elems - 1);
+			}
+		}
+
+		// One-shot diagnostic: dump the layout of mModelData + mModelFiles
+		// and the first uint32 of every non-null bucket-chain node.  Used
+		// to figure out why key lookups fail — whether the symbol address
+		// is wrong, whether StringIntern produces the wrong hash, or
+		// whether the key offset/layout is wrong.
+		static bool g_dumped_once = false;
+		static void dump_hashtable_state(const char* label, uint8_t* ht, size_t mpnext_off)
+		{
+			if (!ht)
+			{
+				LOG(INFO) << "[CG3H DUMP] " << label << " = NULL";
+				return;
+			}
+
+			auto buckets = load<uint8_t*>(ht, HT_BUCKETS);
+			auto count   = load<size_t>(ht, HT_COUNT);
+			auto elems   = load<size_t>(ht, HT_ELEMS);
+
+			LOG(INFO) << "[CG3H DUMP] " << label
+			          << " addr=" << (void*)ht
+			          << " buckets=" << (void*)buckets
+			          << " count=" << std::dec << count
+			          << " elems=" << elems;
+
+			if (!buckets || count <= 1) return;
+
+			int dumped = 0;
+			for (size_t i = 0; i < count && dumped < 300; i++) {
+				void* node = *reinterpret_cast<void**>(buckets + i * sizeof(void*));
+				while (node && dumped < 300) {
+					uint32_t k = load<uint32_t>(node, 0);
+					LOG(INFO) << "[CG3H DUMP]   " << label << " bucket=" << std::dec << i
+					          << " key=0x" << std::hex << k;
+					node = load<void*>(node, mpnext_off);
+					dumped++;
+				}
+			}
+			LOG(INFO) << "[CG3H DUMP] " << label << " dumped " << std::dec << dumped << " entries";
+		}
+
+		static void dump_once_if_needed()
+		{
+			if (g_dumped_once) return;
+			g_dumped_once = true;
+
+			LOG(INFO) << "[CG3H DUMP] ─── hashtable state dump ───";
+			LOG(INFO) << "[CG3H DUMP] g_LoadModelData=" << (void*)g_LoadModelData;
+			LOG(INFO) << "[CG3H DUMP] g_StringIntern=" << (void*)g_StringIntern;
+			LOG(INFO) << "[CG3H DUMP] g_mModelData=" << (void*)g_mModelData;
+			LOG(INFO) << "[CG3H DUMP] g_mModelFiles=" << (void*)g_mModelFiles;
+			LOG(INFO) << "[CG3H DUMP] g_GrannyFreeMeshBinding=" << (void*)g_GrannyFreeMeshBinding;
+			LOG(INFO) << "[CG3H DUMP] g_GrannyFreeTrackMask=" << (void*)g_GrannyFreeTrackMask;
+
+			// Also try a few variations of the character name to see which
+			// hash the game actually uses.
+			if (g_StringIntern) {
+				const char* names[] = {
+					"Hecate", "Hecate_Mesh", "Hecate.gpk",
+					"HecateBattle_Mesh", "HecateHub_Mesh",
+					"Melinoe", "Melinoe_Mesh",
+					"Blank_Mesh",
+				};
+				for (const auto* n : names) {
+					uint32_t h = g_StringIntern(n, 0);
+					LOG(INFO) << "[CG3H DUMP] StringIntern(\"" << n << "\") = 0x"
+					          << std::hex << h;
+				}
+			}
+
+			dump_hashtable_state("mModelData", g_mModelData, MD_NODE_MPNEXT);
+			dump_hashtable_state("mModelFiles", g_mModelFiles, MF_NODE_MPNEXT);
+			LOG(INFO) << "[CG3H DUMP] ─── end dump ───";
+		}
+	} // namespace cg3h_reload
+
+	// Lua API: Function
+	// Table: data
+	// Name: reload_character_model
+	// Param: name: string: Granny character name (e.g. "Hecate", "Melinoe").
+	// Re-reads one character's Granny model from disk via the file redirect
+	// set up by add_granny_file.  Evicts the in-memory cached state and
+	// calls sgg::Granny3D::LoadModelData to re-parse.  Use in concert with
+	// add_granny_file for runtime mesh hot-reload.
+	static void reload_character_model(const std::string& name)
+	{
+		using namespace cg3h_reload;
+
+		if (!ensure_symbols())
+		{
+			LOG(ERROR) << "CG3H: reload_character_model(" << name
+			           << ") — symbol init failed";
+			return;
+		}
+
+		// Diagnostic dump disabled — served its purpose (confirmed key
+		// format is mesh entry names, not character names).  The 277+
+		// entry dump blocks the main thread too long and risks a render
+		// thread timeout / race crash.
+		// dump_once_if_needed();
+
+		LOG(INFO) << "CG3H: reload_character_model(" << name << ")";
+
+		uint32_t hash = g_StringIntern(name.c_str(), 0);
+		LOG(INFO) << "CG3H: hash for \"" << name << "\" = 0x" << std::hex << hash;
+
+		// v3.8.0: we do NOT evict the mModelData entry before reloading.
+		// Eviction frees MeshBinding* and bone-binding pointers that the
+		// render thread may be reading mid-frame, causing a race-crash.
+		// Instead we leave the existing entry in place and let
+		// AddModelData (called by LoadModelData) do an in-place upsert
+		// via DoInsertValue returning the existing entry pointer.  The
+		// old MeshBinding* pointers become orphaned (small leak per
+		// reload), but the render thread never sees a null/freed entry.
+		//
+		// v3.8.1+ can add proper mutex-guarded eviction by taking
+		// App::INSTANCE->mLogicFrameAllocator.mMutex around the full
+		// evict+load sequence, eliminating the leak.
+
+		// Stub mModelFiles (null pointers, keep node).  We tried removing
+		// the node but _aligned_free on EASTL-allocated nodes corrupts
+		// the heap.  Stub is safe — causes cascading reloads on scene
+		// transitions but the 4x pool expansion absorbs the pressure.
+		{
+			uint8_t* mf_node = static_cast<uint8_t*>(
+			    find_node_in_bucket(g_mModelFiles, hash, MF_NODE_MPNEXT, nullptr, nullptr));
+			if (mf_node)
+			{
+				store<void*>(mf_node, MF_NODE_FILE, nullptr);
+				store<void*>(mf_node, MF_NODE_FILEINFO, nullptr);
+				store<void*>(mf_node, MF_NODE_MODEL, nullptr);
+				LOG(INFO) << "CG3H reload: stubbed mModelFiles for hash " << std::hex << hash;
+			}
+		}
+
+		// Zero the GrannyMeshData vector size on the existing mModelData
+		// entry BEFORE calling LoadModelData.  AddModelData uses
+		// emplace_back, so on an existing entry it APPENDS to the old
+		// vector — creating N_old + N_new entries, which overflows the
+		// capacity and triggers a reallocation that races with the
+		// render thread.  By setting mpEnd = mpBegin, we make AddModelData
+		// think the vector is empty and write from the start.  The old
+		// mesh data stays allocated (small leak) but isn't freed, so the
+		// render thread never hits freed memory during the transition.
+		{
+			void* node = find_node_in_bucket(
+			    g_mModelData, hash, MD_NODE_MPNEXT, nullptr, nullptr);
+			if (node)
+			{
+				uint8_t* n     = static_cast<uint8_t*>(node);
+				void* mp_begin = load<void*>(n, MD_NODE_VEC_BEGIN);
+				store<void*>(n, MD_NODE_VEC_END, mp_begin);
+				LOG(INFO) << "CG3H reload: zeroed mesh vector for hash "
+				          << std::hex << hash;
+			}
+		}
+
+		g_LoadModelData({hash});
+
+		// After LoadModelData completes, the mModelFiles stub still has
